# =============================================================================
# EERF Platform Account 설정 (Example)
# =============================================================================
# 이 파일을 terraform.tfvars.shared로 복사하여 실제 값을 입력하세요.
# =============================================================================

region             = "ap-northeast-2"
name_prefix        = "eerf"
notification_email = "ops-team@yourcompany.com"

org_id = "o-your-org-id"

discovery_targets = []
discovery_target_role_arns = []

enable_scheduled_discovery    = true
discovery_schedule_expression = "rate(1 day)"

services = {}

ses_from_email = "eerf@yourcompany.com"
ses_to_emails  = "ops@yourcompany.com"
